# Display Brightness
XF86MonBrightnessDown
	brightnessctl s 5%-
XF86MonBrightnessUp
	brightnessctl s 5%+

# Volume
XF86AudioMute
	pactl set-sink-mute 0 toggle
XF86AudioLowerVolume
	pactl set-sink-volume 0 -5%
XF86AudioRaiseVolume
	pactl set-sink-volume 0 +5%

# Refresh i3status on mute/unmute
@XF86AudioMute
	pkill -SIGUSR1 i3status
@XF86AudioLowerVolume
	pkill -SIGUSR1 i3status
@XF86AudioRaiseVolume
	pkill -SIGUSR1 i3status
