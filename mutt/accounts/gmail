# vim:ft=muttrc:

# Receive options
set delete=yes
set move=no
set imap_user="panayiotis.tembriotis@gmail.com"
set spoolfile="+gmail/INBOX"
set postponed="+gmail/[Gmail].Drafts"
set record="+gmail/INBOX"

# Send options
set sendmail="/usr/bin/msmtp"
set use_from=yes
set realname="Panayiotis Tembriotis"
set from="panayiotis.tembriotis@gmail.com"
set envelope_from=yes

# Connection options
set ssl_force_tls=yes

# Macros
macro index D "<save-message>+gmail/[Gmail].Trash<enter>" "Delete message"
macro index S "<save-message>+gmail/[Gmail].Spam<enter>" "Mark message as Spam"
# Change folder
macro index 'gi' '<change-folder>=gmail/INBOX<enter>' "go to Gmail INBOX"
macro index 'gd' '<change-folder>=gmail/[Gmail].Drafts<enter>' "go to Gmail Drafts"
macro index 'gt' '<change-folder>=gmail/[Gmail].Sent<quote-char> Mail<enter>' "go to Gmail Sent Mail"
macro index 'gs' '<change-folder>=gmail/[Gmail].Starred<enter>' "go to Gmail Starred"
macro index 'gli' '<change-folder>=gmail/[Gmail].Important<enter>' "go to Gmail Important"
macro index 'gls' '<change-folder>=gmail/[Gmail].Spam<enter>' "go to Gmail Spam"
macro index 'glt' '<change-folder>=gmail/[Gmail].Trash<enter>' "go to Gmail Trash"
