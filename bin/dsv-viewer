#!/bin/sh

if [ ${#} -ne 1 ] || ! [ -f "${1}" ]; then
	echo "Usage: `basename ${0}` DELIMITED_FILENAME" >&2
	exit 1
fi

case `basename ${0}` in
	csv-viewer)
		SEPARATOR=','
		;;
	ssv-viewer)
		SEPARATOR=';'
		;;
	*)
		echo "Unknown command" >&2
		exit 1
		;;
esac

column --separator ${SEPARATOR} --table < ${1} \
	| less --LINE-NUMBERS --chop-long-lines
