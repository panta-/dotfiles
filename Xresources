! Xft settings {{{
! force DPI value for DELL XPS 9360 QHD+
Xft.dpi:       277
!Xft.antialias: true
!Xft.autohint:  false
!Xft.hinting:   true
!Xft.hintstyle: hintslight
!Xft.lcdfilter: lcddefault
!Xft.rgba:      rgb
!}}}

! XTerm {{{
XTerm*faceName:  xft:DejaVu Sans Mono:style=Book:size=9
UXTerm*faceName: xft:DejaVu Sans Mono:style=Book:size=9
!}}}

! URxvt settings {{{
URxvt.font:              xft:DejaVu Sans Mono:style=Book:size=9
URxvt.boldFont:          xft:DejaVu Sans Mono:style=Bold:size=9
URxvt.italicFont:        xft:DejaVu Sans Mono:style=Oblique:size=9
URxvt.boldItalicFont:    xft:DejaVu Sans Mono:style=Bold Oblique:size=9
URxvt.letterSpace:       -2
URxvt.fading:            10
URxvt.reverseVideo:      false
URxvt.intensityStyles:   false
URxvt.urgentOnBell:      true
URxvt.pointerBlank:      true
URxvt.saveLines:         1000
URxvt.scrollBar:         false
URxvt.scrollTtyKeypress: true
URxvt.scrollTtyOutput:   false
URxvt.scrollWithBuffer:  true
URxvt.perl-ext-common:   default,selection-to-clipboard,matcher
URxvt.url-launcher:      /usr/bin/xdg-open
URxvt.matcher.button:    1
URxvt.keysym.M-u:        matcher:select
URxvt.keysym.M-l:        matcher:list
!}}}
