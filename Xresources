!}}}

! URxvt settings {{{
URxvt.font:			xft:DejaVu Sans Mono:style=Book:size=8
URxvt.boldFont:			xft:DejaVu Sans Mono:style=Bold:size=8
URxvt.italicFont:		xft:DejaVu Sans Mono:style=Oblique:size=8
URxvt.boldItalicFont:		xft:DejaVu Sans Mono:style=Bold Oblique:size=8
URxvt.letterSpace:		-1
URxvt.fading:			10
URxvt.reverseVideo:		false
URxvt.intensityStyles:		false
