
! Xcursor {{{
Xcursor*size:                         48
Xcursor*theme:                        Vanilla-DMZ-AA
!}}}

! Xft settings {{{
Xft*dpi:                              227	
Xft*antialias:                        true
Xft*hinting:                          true
Xft*hintstyle:                        hintfull
Xft*rgba:                             rgb
!}}}

! dzen2 {{{
dzen2*background:                     black
dzen2*font:                           -xos4-terminus-medium-r-normal--28-280-72-72-c-140-iso10646-1
dzen2*foreground:                     #22EE11
!}}}

! xpdf {{{
xpdf*antialias:                       yes
xpdf*background:                      white
xpdf*enableFreetype:                  yes
xpdf*foreground:                      black
xpdf*urlCommand:                      /usr/bin/chromium %s
!}}}

! xterm {{{
xterm*faceName:                       xft:Source Code Pro:style=Regular:size=8
XTerm*locale:													true
!}}}

! URxvt settings {{{
URxvt*reverseVideo:                   false
URxvt*font:                           xft:Source Code Pro:style=Regular:size=8
URxvt*boldFont:                       xft:Source Code Pro:style=Bold:size=8
URxvt*saveLines:                      1000
URxvt*scrollBar:                      false
URxvt*scrollBar_right:                false
URxvt*scrollstyle:                    rxvt
URxvt*scrollTtyKeypress:              true
URxvt*scrollTtyOutput:                false
URxvt*scrollWithBuffer:               true
URxvt*perl-ext-common:                default,matcher
URxvt*matcher.button:                 1
URxvt*url-launcher:                   /usr/bin/chromium
URxvt*keysym.C-Delete:                perl:matcher:last
URxvt*keysym.M-Delete:                perl:matcher:list
URxvt*urgentOnBell:                   true
!}}}

