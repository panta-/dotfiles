clear Control
clear Lock
clear Mod1
clear Mod3
clear Mod4
keycode  37 = ISO_Level3_Shift Multi_key
keycode  64 = Super_L
keycode  66 = Alt_L Meta_L
keycode 108 = Super_R
keycode 133 = Control_L
keycode 134 = Hyper_L
add Control = Control_L Control_R
add Mod1 = Alt_L Meta_L
add Mod3 = Hyper_L
add Mod4 = Super_L Super_R
