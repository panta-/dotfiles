	name = Panayiotis Tembriotis
[core]
	abbrev = 12
[pretty]
	fixes = Fixes: %h (\"%s\")
[sendemail]
	smtpserver = /usr/bin/msmtp
[push]
	default = simple
[web]
	browser = xdg-open
[alias]
	aliases = config --get-regexp '^alias\\.'
	co = checkout
	last = log -1 HEAD
	st = status -sb
	unstage = reset HEAD --
	visual = !gitk
