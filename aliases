# vim:ft=sh:

alias sudo='sudo '

alias df='df -Th'
alias psc='ps xawf -eo pid,user,cgroup,args'

# gvim
alias g='gvim --servername GVIM --remote-silent'

# mpv to tv
alias tv='mpv --profile=tv'
alias tv-sop='mpv --profile=tv http://localhost:8908/tv.asf'

# pacman
alias p='pacman'
alias pp='sudo pacman -Syu'
alias pcc='sudo pacman -Sc'

# cower
alias c='cower'
alias cuv='cower -uv'

# systemd
alias sd='systemctl'
alias jj='journalctl'

# rtorrent
alias rt='SESSIONNAME=rt && (/usr/bin/tmux attach-session -d -t $SESSIONNAME || /usr/bin/tmux new-session -s $SESSIONNAME -n rtorrent -d rtorrent)'

# mutt
alias mt='urxvtc +rv -is -name mail -e sh -c "mutt"'
