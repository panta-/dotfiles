# vim:ft=sh:

alias sudo='sudo '

alias mv=' mv -i'
alias rm=' rm -I --one-file-system'
alias shred=' shred -v'

alias df='df -Th'
alias pss='ps -Hfljyu $USER'
alias psc='ps xawf -eo pid,user,cgroup,args'

# gvim
alias g='gvim --remote-silent'

# mpv to tv
alias tv='mpv --profile=tv'
alias tv-sop='mpv --profile=tv http://localhost:8908/tv.asf'

# R
alias RR='urxvtc -fade 0 -is -name R -e sh -c "tmux -2 new-session -s R"'
alias rr='vim --class R --servername VIM --remote-silent'

# pacman
alias p='pacman'
alias pp='sudo pacman -Syu'
alias pcc='sudo pacman -Sc'

# cower
alias c='cower'
alias cuv='cower -uv'

# systemd
alias sd='systemctl'
alias jj='journalctl'

# git
alias diffstat='git diff -M --stat --summary'

# rtorrent
alias rt='/usr/bin/tmux new-session -s rt -n rtorrent -d rtorrent'
alias tt='/usr/bin/tmux attach-session -d -t rt'

# mutt
alias mt='urxvtc +rv -is -name mail -e sh -c "mutt"'
