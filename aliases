alias sudo='sudo '

alias ls='ls --color=auto -F'
alias l='ls -l'
alias ll='l'
alias la='ls -a'
alias grep='grep --color=auto'

alias da='du -sh'
alias df='df -Th'
alias psc='ps xawf -eo pid,user,cgroup,args'

# gvim
alias g='gvim --servername GVIM --remote-silent'

# mpv profiles
alias au='mpv --profile=audio'
alias tv='mpv --profile=tv'
alias tv-sop='mpv --profile=tv http://localhost:8908/tv.asf'

# pacman
alias p='pacman'
alias pp='sudo pacman -Syu'

# cower
alias c='cower'
alias cuv='cower -uv'

# systemd
alias sd='systemctl'
alias jj='journalctl'

# mutt
alias mt='termite --name=mail -e "neomutt"'
