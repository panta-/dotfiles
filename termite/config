[options]
#allow_bold = true
#audible_bell = false
#bold_is_bright = true
clickable_url = false
#dynamic_title = true
font = FiraCode, FontAwesome5Free, FontAwesome5Brands 9
#fullscreen = true
geometry = 1920x1440
#icon_name = terminal
mouse_autohide = true
#scroll_on_output = false
#scroll_on_keystroke = true
# Length of the scrollback buffer, 0 disabled the scrollback buffer
# and setting it to a negative value means "infinite scrollback"
scrollback_lines = 10000
search_wrap = false
#urgent_on_bell = true
hyperlinks = true

# $BROWSER is used by default if set, with xdg-open as a fallback
#browser = xdg-open

# "system", "on" or "off"
#cursor_blink = system

# "block", "underline" or "ibeam"
#cursor_shape = block

# Hide links that are no longer valid in url select overlay mode
#filter_unmatched_urls = true

# Emit escape sequences for extra modified keys
#modify_other_keys = false

# set size hints for the window
#size_hints = false

# "off", "left" or "right"
#scrollbar = off

[colors]
# Solarized Light
# Author: Ethan Schoonover (http://ethanschoonover.com/solarized)

cursor            = #93a1a1
cursor_foreground = #586e75

foreground      = #657b83
foreground_bold = #657b83
background      = #fdf6e3

highlight = #586e75

color0  = #eee8d5
color1  = #dc322f
color2  = #859900
color3  = #b58900
color4  = #268bd2
color5  = #d33682
color6  = #2aa198
color7  = #073642
color8  = #fdf6e3
color9  = #cb4b16
color10 = #93a1a1
color11 = #839496
color12 = #657b83
color13 = #6c71c4
color14 = #586e75
color15 = #002b36

[hints]
font = FiraCode 24
foreground = #586e75
background = #93a1a1
active_foreground = #93a1a1
active_background = #586e75
padding = 2
border = #586e75
border_width = 0.5
roundness = 0.0

